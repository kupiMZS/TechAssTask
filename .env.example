# ============================================
# SERVER CONFIGURATION
# ============================================
# The IP address or domain of your server
SERVER_HOST=localhost

# Your SSH username for the server
SERVER_USER=kabbo

# Where your project lives on the server
DEPLOY_PATH=/home/kabbo/Desktop/Project/TechAssTask

# ============================================
# PORT CONFIGURATION
# ============================================
# Port for Nginx (HTTP)
NGINX_PORT=80

# Internal ports for the websites
SITE1_PORT=80
SITE2_PORT=80

# ============================================
# DOMAIN CONFIGURATION
# ============================================
# Domain name for the websites
DOMAIN_NAME=localhost

# ============================================
# DOCKER CONFIGURATION
# ============================================
# Docker Compose file to use
COMPOSE_FILE=docker-compose.yml

# ============================================
# GITHUB ACTIONS (for CI/CD)
# ============================================
# These are stored in GitHub Secrets
# SSH_PRIVATE_KEY=your-private-key-content