# ============================================
# SERVER CONFIGURATION
# ============================================

# Server IP address or domain name
# Example: SERVER_HOST=192.168.1.100 or my-server.com
SERVER_HOST=

# SSH username for the server
# Example: SERVER_USER=ubuntu or ec2-user
SERVER_USER=

# Path where the project will be deployed
# Example: DEPLOY_PATH=/home/ubuntu/TechAssTask
DEPLOY_PATH=

# ============================================
# NGINX CONFIGURATION
# ============================================

# Port on which Nginx will listen (default: 80)
# Example: NGINX_PORT=80
NGINX_PORT=

# Domain name for the websites (default: localhost)
# Example: DOMAIN_NAME=localhost or mywebsite.com
DOMAIN_NAME=

# Internal port for Site 1 (default: 80)
SITE1_PORT=

# Internal port for Site 2 (default: 80)
SITE2_PORT=